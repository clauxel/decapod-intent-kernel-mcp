{
  "name": "decapodkernel",
  "title": "Decapod Intent Kernel",
  "description": "A paid remote MCP for Decapod, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://decapodkernel.clauxel.com/",
  "documentationUrl": "https://decapodkernel.clauxel.com/mcp/",
  "endpointUrl": "https://decapodkernel.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://decapodkernel.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://decapodkernel.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://decapodkernel.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "solo",
        "name": "Solo",
        "monthlyUsd": 39
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 139
      },
      {
        "id": "delivery",
        "name": "Delivery",
        "monthlyUsd": 449
      }
    ]
  },
  "tools": [
    {
      "name": "create_intent_contract",
      "description": "Decapod Intent Kernel create intent contract",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sample": {
            "type": "string",
            "description": "Workflow sample, schema, policy fixture, or agent output."
          },
          "context": {
            "type": "string",
            "description": "Optional review context."
          }
        },
        "required": [
          "sample"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "verdict": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "receipt_id": {
            "type": "string"
          },
          "usage_units": {
            "type": "integer"
          },
          "next_action": {
            "type": "string"
          }
        }
      }
    },
